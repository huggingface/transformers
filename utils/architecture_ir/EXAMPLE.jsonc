// ============================================================================================
// Architecture IR — annotated example ArchitectureTemplate (v0)
//
// A HAND-ANNOTATED, TRIMMED copy of a real artifact (JSONC = JSON + // comments, so NOT
// machine-parseable as-is). It mirrors the actual `artifacts/mistral.json` — a modular, GQA,
// sliding-window decoder LLM — with "…" marking omitted repetition, and doubles as a tour of what
// the generator extracts. Regenerate the exact (comment-free) file with:
//     python utils/architecture_ir/generate_architecture_ir.py --architectures mistral --output-dir out
// See SPEC.md §12 for the full key-by-key contract. Inline notes point out where OTHER model
// families (MoE, encoder, enc-dec, multimodal) differ.
//
// The artifact is kept LEAN: only non-derivable data. Notably absent by design — `metadata`
// (implied by schema_version), `entrypoints` (folded into provenance), a `modularity` summary
// (is_modular == extends!=null; the diff_size metric lives in modular_graph.json), per-node
// `module` (same string on every node), empty `children: []`, and empty patch member buckets.
// ============================================================================================
{
  "schema_version": "architecture-template-v0",   // contract version
  "model_type": "mistral",                         // one template per model_type

  // -- Modular inheritance: just the parent + the change payload -----------------------------
  // Recovered by parsing modular_mistral.py with `ast` (no torch). Standalone models (llama, bert)
  // have extends=null and no `patches`. Trivial (inherit-everything) classes and empty member
  // buckets are omitted. The cross-model diff_size metric lives in modular_graph.json, not here.
  "extends": "llama",
  "patches": [
    {
      "relation": "inherits",                      // "inherits" (overrides a parent class) | "new"
      "target_class": "MistralAttention",          // provenance: the modular Python class
      "component_kind": "attention",               // semantic projection of that class (may be null)
      "parent_class": "LlamaAttention",            // parent_model omitted → it's the dominant `extends`
      "overridden": { "methods": ["__init__", "forward"] }   // only non-empty buckets are emitted
    },
    {
      "relation": "new",                           // a brand-new class (no parent equivalent)
      "target_class": "MistralForQuestionAnswering", "component_kind": null,
      "parent_class": "MistralPreTrainedModel"
    }
    // … other overridden classes (MistralMLP, MistralModel, …). Heavier models show
    //   component_kind:"moe", real `added`/`deleted` lists, and many relation:"new" entries.
  ],

  // -- Normalized model-level facts (WHAT it is) — multimodal reads the text backbone --------
  "architecture": {
    "view": "decoder",                             // decoder | encoder | enc_dec | multimodal
    "family": "causal_lm",                         // task family via Auto* mappings
    "attention_variant": "GQA",                    // MHA | GQA | MQA | MLA
    "positional": "rope",                          // rope | relative | alibi | learned | sinusoidal
    "is_moe": false,
    "sliding_window": 4096,
    "tie_word_embeddings": false
    // "moe": { "num_experts": 8, "experts_per_token": 2 }   // present ONLY for MoE models
  },

  // -- Capabilities (WHAT it can do / run with) — implementation-agnostic --------------------
  "capabilities": {
    "attention_backends": ["eager", "sdpa", "flash_attention", "flex_attention"],  // "can run with"
    "attention_patterns": ["sliding"],             // distinct per-layer mask kinds
    "attention_schedule": null,                    // raw config.layer_types when NON-uniform, else null
    "task_heads": ["causal_lm", "question_answering", "sequence_classification", "token_classification"],
    "tensor_parallel": true                        // ships base_model_tp_plan → projections get `tp`
  },

  // -- Config: identity + ONLY the parametric surface (full config is NOT serialized) --------
  "config": {
    "class_name": "MistralConfig",
    "module": "transformers.models.mistral.configuration_mistral",
    "model_type": "mistral",
    "referenced_fields": { "num_hidden_layers": 32 },   // fields referenced by config expressions
    "salient_fields": {                                 // curated scalar defaults (not the full config)
      "hidden_size": 4096, "intermediate_size": 14336, "vocab_size": 32000,
      "num_attention_heads": 32, "num_key_value_heads": 8, "head_dim": 128,
      "max_position_embeddings": 131072, "sliding_window": 4096, "hidden_act": "silu",
      "tie_word_embeddings": false
    }
  },

  // -- Components reachable OUTSIDE any repeat body ------------------------------------------
  // `id` is the stable semantic identity; class_name/path_pattern are provenance. Leaf nodes omit
  // `children`. Per-node `module` is intentionally absent (see header).
  "components": [
    {
      "id": "model", "kind": "model", "class_name": "MistralModel", "path_pattern": "model",
      "children": ["embed_tokens", "decoder_layers", "norm", "rotary_emb"]   // note: the repeat id
    },
    { "id": "embed_tokens", "kind": "embedding", "class_name": "Embedding", "path_pattern": "model.embed_tokens",
      "attributes": { "num_embeddings": "config.vocab_size", "embedding_dim": "config.hidden_size" } },
    { "id": "norm", "kind": "normalization", "class_name": "MistralRMSNorm", "path_pattern": "model.norm",
      "attributes": { "norm_type": "rms" } },      // rms | layer | group | batch
    { "id": "rotary_emb", "kind": "position", "class_name": "MistralRotaryEmbedding", "path_pattern": "model.rotary_emb",
      "attributes": { "scheme": "rope", "rope_theta": 10000.0, "head_dim": "config.head_dim" } }
    // Multimodal models keep their sub-model wrappers here too (vision_tower, language_model,
    // multi_modal_projector, kind "module") so the tree stays reachable from the root.
  ],

  // -- Templates: the repeated BLOCK body, serialized ONCE (never per layer instance) --------
  "templates": [
    { "id": "decoder_layer", "kind": "transformer_block", "class_name": "MistralDecoderLayer",
      "path_pattern": "model.layers.{i}",          // {i} = the symbolic layer index
      "children": ["decoder_layer.input_layernorm", "decoder_layer.self_attn",
                   "decoder_layer.post_attention_layernorm", "decoder_layer.mlp"] },
    { "id": "decoder_layer.self_attn", "kind": "attention", "class_name": "MistralAttention",
      "path_pattern": "model.layers.{i}.self_attn",
      "children": ["decoder_layer.self_attn.q_proj", "decoder_layer.self_attn.k_proj",
                   "decoder_layer.self_attn.v_proj", "decoder_layer.self_attn.o_proj"],
      "attributes": { "variant": "GQA", "n_heads": 32, "n_kv_heads": 8, "head_dim": 128,
                      "rope": true, "sliding_window": 4096, "pattern": "sliding" } },
    // Projections are descended into (once, in the template) with config-parametric dims + TP style.
    // GQA shows here: q/o are hidden-sized; k/v are the smaller num_kv_heads*head_dim = 1024.
    { "id": "decoder_layer.self_attn.q_proj", "kind": "projection", "class_name": "Linear",
      "path_pattern": "model.layers.{i}.self_attn.q_proj",
      "attributes": { "in_features": "config.hidden_size", "out_features": 4096, "tp": "colwise" } },
    { "id": "decoder_layer.self_attn.k_proj", "kind": "projection", "class_name": "Linear",
      "path_pattern": "model.layers.{i}.self_attn.k_proj",
      "attributes": { "in_features": "config.hidden_size", "out_features": 1024, "tp": "colwise" } },
    // … v_proj (out 1024, colwise), o_proj (in 4096 → config.hidden_size, tp "rowwise")
    { "id": "decoder_layer.mlp", "kind": "feed_forward", "class_name": "MistralMLP",
      "path_pattern": "model.layers.{i}.mlp",
      "children": ["decoder_layer.mlp.gate_proj", "decoder_layer.mlp.up_proj", "decoder_layer.mlp.down_proj"],
      "attributes": { "hidden_size": 4096, "intermediate_size": 14336, "activation": "silu" } },
      // A MoE model has kind "moe" here with { num_experts, experts_per_token } + a "route" edge.
    { "id": "decoder_layer.mlp.gate_proj", "kind": "projection", "class_name": "Linear",
      "path_pattern": "model.layers.{i}.mlp.gate_proj",
      "attributes": { "in_features": "config.hidden_size", "out_features": "config.intermediate_size", "tp": "colwise" } },
    // … up_proj (colwise), down_proj (config.intermediate_size → config.hidden_size, tp "rowwise")
    { "id": "decoder_layer.input_layernorm", "kind": "normalization", "class_name": "MistralRMSNorm",
      "path_pattern": "model.layers.{i}.input_layernorm", "attributes": { "norm_type": "rms" } }
    // … post_attention_layernorm
  ],

  // -- Symbolic repeats: 32 identical layers collapsed to ONE entry, count kept parametric ----
  "repeats": [
    { "id": "decoder_layers", "kind": "symbolic_repeat",
      "body": "decoder_layer",                     // the template above
      "count_expr": "config.num_hidden_layers",    // a restricted expression string, never exec'd
      "count_source": "config",                    // config | module_tree
      "count": 32,                                 // observed under the DEFAULT config (provenance)
      "index_symbol": "i",
      "container_path_pattern": "model.layers",
      "item_path_pattern": "model.layers.{i}",
      "repeated_class_name": "MistralDecoderLayer" }
  ],

  // -- Coarse semantic dataflow edges between semantic IDs ------------------------------------
  "edges": [
    { "source": "embed_tokens", "target": "decoder_layers", "kind": "data" },       // main path
    { "source": "decoder_layers", "target": "norm", "kind": "data" },
    // block-level flow, re-grounded from an observed forward (pre-norm order):
    { "source": "decoder_layer.input_layernorm", "target": "decoder_layer.self_attn", "kind": "data", "provenance": "observed_forward" },
    { "source": "decoder_layer.self_attn", "target": "decoder_layer.post_attention_layernorm", "kind": "data", "provenance": "observed_forward" },
    { "source": "decoder_layer.post_attention_layernorm", "target": "decoder_layer.mlp", "kind": "data", "provenance": "observed_forward" },
    // intra-module fan-out / fan-in (role-based, so q/k/v are parallel — not a chain):
    { "source": "decoder_layer.self_attn", "target": "decoder_layer.self_attn.q_proj", "kind": "data", "provenance": "intra_module" },
    { "source": "decoder_layer.self_attn.q_proj", "target": "decoder_layer.self_attn.o_proj", "kind": "data", "provenance": "intra_module" },
    { "source": "decoder_layer.mlp.gate_proj", "target": "decoder_layer.mlp.down_proj", "kind": "data", "provenance": "intra_module" },
    // residual, positional, mask, and KV-cache edges:
    { "source": "decoder_layer", "target": "decoder_layer.self_attn", "kind": "residual" },
    { "source": "rotary_emb", "target": "decoder_layer.self_attn", "kind": "position" },
    { "source": "input:attention_mask", "target": "decoder_layer.self_attn", "kind": "mask" },
    { "source": "state:kv_cache", "target": "decoder_layer.self_attn", "kind": "cache_read" },
    { "source": "decoder_layer.self_attn", "target": "state:kv_cache", "kind": "cache_write" }
    // Encoder-decoder models also emit "cross_attention" edges; MoE models emit "route" edges.
    // edge kinds: data | residual | mask | position | cross_attention | route | cache_read | cache_write
  ],

  // -- Observed dataflow: shapes ONLY (order lives in `edges`); shapes are SYMBOLIZED ---------
  // A flat lookup keyed by semantic id. Absent entirely when the forward can't run on meta.
  "dataflow": {
    "source": "observed_forward_meta",
    "input":  { "name": "input_ids", "shape": ["B", "S"] },   // B=batch, S=sequence
    "output": { "shape": ["B", "S", "config.hidden_size"] },
    "shapes": {
      "embed_tokens":   { "in": ["B", "S"], "out": ["B", "S", "config.hidden_size"] },
      "decoder_layers": { "in": ["B", "S", "config.hidden_size"], "out": ["B", "S", "config.hidden_size"] },
      "decoder_layer.self_attn": { "in": ["B", "S", "config.hidden_size"], "out": ["B", "S", "config.hidden_size"] }
      // … norm, and the other block children, keyed by their semantic id
    }
  },

  // -- Provenance: just the source classes (resolution strategy is invariant → in SPEC, not here) --
  "provenance": {
    "config_class": "MistralConfig", "config_module": "transformers.models.mistral.configuration_mistral",
    "model_class": "MistralModel",   "model_module": "transformers.models.mistral.modeling_mistral"
  }
  // "warnings": [ ... ]   // present only when there are non-fatal generation warnings
}
