      "pluginVersion": "12.0.0",
      "targets": [
        {
          "editorMode": "code",
          "expr": "sort_desc(pytest_test_average_duration_seconds{service_name=~\"$service\",test_job=~\"$job\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Slowest Tests By Average Duration",
      "transformations": [
        {
          "id": "organize",
          "options": {
                    "excludeByName": {
                      "Time": true,
                      "__name__": true,
                      "instance": true,
                      "job": true,
                      "provider": true,
                      "status_code": true,
                      "test_nodeid": true
                    },
                    "indexByName": {
                      "test_module": 0,
                      "test_class": 1,
                      "test_function": 2,
                      "service_name": 3,
                      "test_job": 4,
                      "trace_id": 5,
                      "Value": 6
                    },
                    "renameByName": {
                      "Value": "Avg Duration (s)",
                      "test_module": "Module",
                      "test_class": "Class",
                      "test_function": "Function",
                      "service_name": "Service",
                      "test_job": "Job",
                      "trace_id": "Trace ID"
                    }
                  }
        }
      ],
      "type": "table"
    },
